PUBLIC_HOST=your-host.example.com
NODE_NAME=my-node
SNI=adm.com

# 推荐部署前固定这些值；不填则容器首次启动自动生成，并写入 /data/identity.env。
UUID=
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
SHORT_ID=
ANYTLS_PASSWORD=

VLESS_TCP_PORT=443
VLESS_HU_PORT=8443
ANYTLS_PORT=9443
SUB_PORT=8080

# 云服务外部端口不同于容器端口时填写外部端口。
EXTERNAL_VLESS_TCP_PORT=443
EXTERNAL_VLESS_HU_PORT=8443
EXTERNAL_ANYTLS_PORT=9443

BLOCK_PRIVATE=true
BLOCK_BITTORRENT=true
